{
  "name": "qr-code-generator",
  "version": "1.0.0",
  "description": "QR Code Generator with AI Icons",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "typecheck": "tsc --noEmit",
    "lint": "biome check --write .",
    "test": "vitest run",
    "check": "pnpm lint && pnpm typecheck && pnpm test"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.4.12",
    "@tailwindcss/vite": "^4.2.4",
    "@types/qrcode": "^1.5.6",
    "tailwindcss": "^4.2.4",
    "typescript": "^6.0.3",
    "vite": "^8.0.9",
    "vitest": "^4.1.5"
  },
  "dependencies": {
    "@google/genai": "^1.50.1",
    "jsqr": "^1.4.0",
    "qrcode": "^1.5.4"
  }
}
